DEERAPI_BASE_URL=https://api.deerapi.com
DEERAPI_API_KEY=
TEXT_MODEL=gpt-4.1-mini
IMAGE_MODEL=gpt-image-2
IMAGE_OUTPUT_FORMAT=png
# Optional: auto, 1024x1024, 1536x1024, 1024x1536, etc. depending on model support
IMAGE_SIZE=auto
# Optional: auto, low, medium, high, etc. depending on model support
IMAGE_QUALITY=auto
OUTPUT_DIR=./output
PORT=3000
# Optional: override the xiaohongshu-cli executable path/name.
XHS_CLI_COMMAND=xhs.cmd
# Optional: auto, edge, chrome, firefox, brave, opera, etc.
XHS_COOKIE_SOURCE=auto
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx
